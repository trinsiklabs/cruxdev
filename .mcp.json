{
  "mcpServers": {
    "cruxdev": {
      "command": "/opt/homebrew/opt/python@3.14/bin/python3.14",
      "args": [
        "-m",
        "src.mcp_server"
      ],
      "cwd": "/Users/user/personal/cruxdev",
      "env": {
        "PYTHONPATH": "/Users/user/personal/cruxdev"
      }
    },
    "crux": {
      "command": "/opt/homebrew/opt/python@3.14/bin/python3.14",
      "args": [
        "-m",
        "scripts.lib.crux_mcp_server"
      ],
      "cwd": "/Users/user/personal/crux",
      "env": {
        "CRUX_PROJECT": "/Users/user/personal/cruxdev",
        "CRUX_HOME": "/Users/user"
      }
    }
  }
}