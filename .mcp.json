{
  "mcpServers": {
    "crux": {
      "type": "stdio",
      "command": "/Users/user/personal/crux/target/release/crux",
      "args": ["mcp", "start"],
      "env": {
        "CRUX_PROJECT": "/Users/user/personal/crux",
        "CRUX_HOME": "/Users/user"
      }
    },
    "cruxdev": {
      "type": "stdio",
      "command": "/Users/user/personal/cruxdev/rust/target/release/cruxdev",
      "args": ["mcp", "start"]
    }
  }
}