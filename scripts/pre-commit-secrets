#!/bin/bash
# Pre-commit hook: block commits containing secret patterns
# Install: cp scripts/pre-commit-secrets .git/hooks/pre-commit

FOUND=0

for pattern in sk-or-v1- sk-ant- sk-proj- ghp_ ghs_; do
  if git diff --cached --no-color -- . ':(exclude)scripts/pre-commit-secrets' ':(exclude)*.sh' ':(exclude)rust/src/install.rs' 2>/dev/null | LC_ALL=C grep -qF "$pattern"; then
    echo "BLOCKED: '$pattern' found in staged changes"
    FOUND=1
  fi
done

if git diff --cached --no-color -- . ':(exclude)scripts/pre-commit-secrets' ':(exclude)*.sh' ':(exclude)rust/src/install.rs' 2>/dev/null | LC_ALL=C grep -qF "PRIVATE KEY"; then
  echo "BLOCKED: Private key found in staged changes"
  FOUND=1
fi

if [ $FOUND -eq 1 ]; then
  echo ""
  echo "Commit blocked. Remove secrets before committing."
  echo "Use environment variables instead of inline secrets."
  exit 1
fi
