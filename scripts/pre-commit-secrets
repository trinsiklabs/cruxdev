#!/bin/bash
# Pre-commit hook: scan staged file CONTENTS for actual secret values
# Install: cp scripts/pre-commit-secrets .git/hooks/pre-commit
#
# Scans added lines (^\+) in staged diffs for real secret patterns.
# Only matches actual key values with sufficient entropy, not pattern
# names in comments or scripts.

FOUND=0

# Get added lines from staged changes
ADDED=$(git diff --cached --diff-filter=ACM -U0 2>/dev/null | grep '^+' | grep -v '^+++')

check_pattern() {
  local label="$1"
  local pattern="$2"
  if echo "$ADDED" | grep -qE -- "$pattern"; then
    echo "BLOCKED: $label found in staged changes"
    FOUND=1
  fi
}

check_pattern "OpenRouter API key"     'sk-or-v1-[a-f0-9]'
check_pattern "Anthropic API key"      'sk-ant-[a-zA-Z0-9]'
check_pattern "OpenAI project key"     'sk-proj-[a-zA-Z0-9]'
check_pattern "GitHub token"           'gh[ps]_[a-zA-Z0-9]'
check_pattern "Private key"           'BEGIN.*PRIVATE KEY'

if [ $FOUND -eq 1 ]; then
  echo ""
  echo "Commit blocked. Remove secrets before committing."
  echo "Use environment variables instead of inline secrets."
  exit 1
fi
